# OpenClarion local Stage 5 worker example.
#
# Copy this file to the repo-local ignored private directory, replace every
# placeholder, then set:
#
#   mkdir -p .openclarion-private
#   cp .env.example .openclarion-private/openclarion-stage5.env
#   chmod 0600 .openclarion-private/openclarion-stage5.env
#   OPENCLARION_STAGE5_WORKER_ENV_FILE=.openclarion-private/openclarion-stage5.env make stage5-local-worker-check
#   OPENCLARION_STAGE5_WORKER_ENV_FILE=.openclarion-private/openclarion-stage5.env make stage5-local-worker
#
# The launcher sources this file as Bash, so keep values quoted when they may
# contain : / ? & = or other shell-significant characters. Do not put real
# credentials in tracked files. The .openclarion-private/ directory is ignored
# by git; a private path outside the repository is also accepted.

# Local control-plane dependencies. The launcher has safe loopback defaults for
# these values, but setting them explicitly avoids ambiguity during proof runs.
DATABASE_URL='postgres://openclarion:openclarion_dev@localhost:25432/openclarion?sslmode=disable'
TEMPORAL_HOST_PORT='localhost:27233'
LISTEN_ADDR='127.0.0.1:32101'
OPENCLARION_TEMPORAL_TASK_QUEUE='openclarion-stage5'

# Optional for service managers: use a prebuilt binary instead of `go run`.
# Leave unset for source-tree local rehearsal.
# OPENCLARION_STAGE5_WORKER_BINARY='/opt/openclarion/bin/openclarion'

# Diagnosis auth and browser origin policy.
OPENCLARION_DIAGNOSIS_OIDC_ISSUER_URL='http://127.0.0.1:18080'
OPENCLARION_DIAGNOSIS_OIDC_CLIENT_ID='openclarion-web'
OPENCLARION_DIAGNOSIS_ALLOWED_ORIGINS='http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:3000,http://localhost:3000'

# OpenAI-compatible report and diagnosis LLM runtime. The launcher derives the
# report variables from the diagnosis variables, or the reverse, when only one
# side is supplied.
OPENCLARION_DIAGNOSIS_LLM_BASE_URL='https://llm.example.test/v1'
OPENCLARION_DIAGNOSIS_LLM_API_KEY='replace-with-private-api-key'
OPENCLARION_DIAGNOSIS_LLM_MODEL='replace-with-model-name'

# Digest-pinned diagnosis assistant sandbox runtime and read-only agent config.
OPENCLARION_SANDBOX_IMAGE_REF='registry.example.test/openclarion/diagnosis-assistant-runner@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa'
OPENCLARION_SANDBOX_AGENT_CONFIG_ROOT='.openclarion-private/agent-config'
OPENCLARION_SANDBOX_EGRESS_ALLOWED='llm.example.test:443,metrics.example.test:443'
OPENCLARION_SANDBOX_EGRESS_NETWORK='openclarion-sandbox-allowlist'

# Diagnosis notification delivery. Diagnosis-room consultation and close
# notifications require the direct IM webhook variables below.
OPENCLARION_IM_WEBHOOK_URL='https://webhook.example.test/openclarion'
OPENCLARION_IM_WEBHOOK_FORMAT='wecom'
