# OpenClarion local product environment example.
#
# Copy this file to the repo-local ignored private directory, replace every
# placeholder, then set:
#
#   mkdir -p .openclarion-private
#   cp .env.example .openclarion-private/openclarion-stage5.env
#   chmod 0600 .openclarion-private/openclarion-stage5.env
#   npm --prefix web ci
#   OPENCLARION_LOCAL_PRODUCT_ENV_FILE=.openclarion-private/openclarion-stage5.env make local-product-check
#   OPENCLARION_LOCAL_PRODUCT_ENV_FILE=.openclarion-private/openclarion-stage5.env make local-product
#
# The launcher sources this file as Bash, so keep values quoted when they may
# contain : / ? & = or other shell-significant characters. Do not put real
# credentials in tracked files. The .openclarion-private/ directory is ignored
# by git; a private path outside the repository is also accepted.

# Local control-plane dependencies. The launcher has safe loopback defaults for
# these values, but setting them explicitly avoids ambiguity during proof runs.
DATABASE_URL='postgres://openclarion:openclarion_dev@localhost:25432/openclarion?sslmode=disable'
TEMPORAL_HOST_PORT='localhost:27233'
LISTEN_ADDR='127.0.0.1:32101'
OPENCLARION_TEMPORAL_TASK_QUEUE='openclarion-stage5'

# Optional for service managers: use a prebuilt binary instead of `go run`.
# Leave unset for source-tree local rehearsal.
# OPENCLARION_STAGE5_WORKER_BINARY='/opt/openclarion/bin/openclarion'
# The complete local launcher uses a dedicated `openclarion_local_product`
# database and isolated Compose project by default. Set this only when Atlas
# should migrate the separately managed DATABASE_URL above.
# OPENCLARION_LOCAL_USE_CONFIGURED_DATABASE='1'
# Atlas runs in a container. If the configured URL uses localhost/127.0.0.1,
# use host networking where supported, or give Atlas a separate
# container-reachable URL and network while leaving DATABASE_URL host-local.
# OPENCLARION_LOCAL_ATLAS_DOCKER_NETWORK='host'
# OPENCLARION_LOCAL_ATLAS_DATABASE_URL='postgres://openclarion:replace-me@database.example.test:5432/openclarion?sslmode=require'
# OPENCLARION_LOCAL_ATLAS_DOCKER_NETWORK='openclarion-local-product_default'

# Diagnosis auth and browser origin policy.
# IAM OIDC is the standard browser entry. When OIDC_ISSUER and OIDC_CLIENT_ID
# or their OPENCLARION_IAM_OIDC_* aliases are set, OpenClarion verifies IAM ID
# tokens and maps IAM claims into local RBAC. LDAP and static auth are explicit
# compatibility paths. Enterprise WeChat browser login is handled upstream by
# IAM, not directly by OpenClarion.
# Keep all credentials only in the ignored private env file.
# OIDC_ISSUER='https://iam.example.test'
# OIDC_CLIENT_ID='openclarion-console'
# OPENCLARION_DIAGNOSIS_OIDC_ISSUER_URL='http://127.0.0.1:18080'
# OPENCLARION_DIAGNOSIS_OIDC_CLIENT_ID='openclarion-web'

# Optional explicit LDAP compatibility path. Role values match the configured
# role attribute, commonly memberOf group DNs.
# OPENCLARION_DIAGNOSIS_AUTH_MODE='ldap'
# OPENCLARION_DIAGNOSIS_LDAP_URL='ldaps://ldap.example.test:636'
# For ldap:// endpoints, prefer StartTLS. Plaintext ldap:// requires the
# explicit insecure allowance and should stay limited to isolated rehearsals.
# OPENCLARION_DIAGNOSIS_LDAP_START_TLS='false'
# OPENCLARION_DIAGNOSIS_LDAP_ALLOW_INSECURE_PLAINTEXT='false'
# OPENCLARION_DIAGNOSIS_LDAP_BASE_DN='dc=example,dc=test'
# OPENCLARION_DIAGNOSIS_LDAP_BIND_DN='cn=openclarion,ou=svc,dc=example,dc=test'
# OPENCLARION_DIAGNOSIS_LDAP_BIND_PASSWORD='replace-with-private-ldap-password'
# OPENCLARION_DIAGNOSIS_LDAP_USER_FILTER='(|(uid={username})(sAMAccountName={username})(mail={username}))'
# OPENCLARION_DIAGNOSIS_LDAP_SUBJECT_ATTRIBUTE='mail'
# OPENCLARION_DIAGNOSIS_LDAP_ROLE_ATTRIBUTE='memberOf'
# OPENCLARION_DIAGNOSIS_LDAP_OWNER_ROLE_VALUES='cn=openclarion-operators,ou=groups,dc=example,dc=test'
# OPENCLARION_DIAGNOSIS_LDAP_ADMIN_ROLE_VALUES='cn=openclarion-admins,ou=groups,dc=example,dc=test'
# OPENCLARION_DIAGNOSIS_LDAP_DEFAULT_ROLES='owner'
# For private-network rehearsals without OIDC, use static auth instead. Keep
# the token only in the ignored private env file.
# OPENCLARION_DIAGNOSIS_AUTH_MODE='static'
# OPENCLARION_DIAGNOSIS_STATIC_BEARER_TOKEN='replace-with-private-diagnosis-token'
# OPENCLARION_DIAGNOSIS_STATIC_SUBJECT='openclarion.local-operator'
# OPENCLARION_DIAGNOSIS_STATIC_ROLES='admin'
# Required by the complete local launcher for OIDC, LDAP, or static credentials
# to become a short-lived HttpOnly browser session. Use at least 32 private bytes.
# OPENCLARION_DIAGNOSIS_SESSION_SIGNING_KEY='replace-with-private-32-byte-session-signing-key'

# Browser IAM sign-in uses the standard OIDC authorization-code flow in the
# Next.js BFF, then exchanges the verified ID token for an OpenClarion diagnosis
# session through the backend diagnosis auth provider. Keep client secrets and
# state signing keys only in the ignored private env file.
# OIDC_ISSUER='https://iam.example.test'
# OIDC_CLIENT_ID='openclarion-console'
# OIDC_CLIENT_SECRET='replace-with-private-oidc-client-secret'
# OIDC_CLIENT_AUTH_METHOD='client_secret_basic'
# OIDC_REDIRECT_URL='https://openclarion.example.test/api/diagnosis/auth/oidc/callback'
# OIDC_SCOPES='openid profile email'
# OIDC_USE_PKCE='true'
# OIDC_STATE_SIGNING_KEY='replace-with-private-32-byte-state-signing-key'
# The OPENCLARION_IAM_OIDC_* aliases are still accepted for deployments that
# prefer product-scoped env names.
# OPENCLARION_IAM_OIDC_ISSUER='https://iam.example.test'
# OPENCLARION_IAM_OIDC_CLIENT_ID='openclarion-console'
# OPENCLARION_IAM_OIDC_CLIENT_SECRET='replace-with-private-oidc-client-secret'
# OPENCLARION_IAM_OIDC_CLIENT_AUTH_METHOD='client_secret_basic'
# OPENCLARION_IAM_OIDC_REDIRECT_URL='https://openclarion.example.test/api/diagnosis/auth/oidc/callback'
# OPENCLARION_IAM_OIDC_SCOPES='openid profile email'
# OPENCLARION_IAM_OIDC_USE_PKCE='true'
# OPENCLARION_IAM_OIDC_STATE_SIGNING_KEY='replace-with-private-32-byte-state-signing-key'
# Local directory projection sync is enabled when DIRECTORY_SCOPES or one of
# the OPENCLARION_IAM_DIRECTORY_* variables is set. It may reuse the IAM/OIDC
# issuer, client id, and client secret above; configure directory-specific
# values only when the directory API uses a different audience or endpoint.
# OPENCLARION_IAM_DIRECTORY_PROVIDER_NAME='ops_iam'
# OPENCLARION_IAM_DIRECTORY_ISSUER='https://iam.example.test'
# OPENCLARION_IAM_DIRECTORY_BASE_URL='https://iam.example.test'
# OPENCLARION_IAM_DIRECTORY_TOKEN_URL='https://iam.example.test/api/login/oauth/access_token'
# OPENCLARION_IAM_DIRECTORY_CLIENT_ID='openclarion-directory-sync'
# OPENCLARION_IAM_DIRECTORY_CLIENT_SECRET='replace-with-private-directory-client-secret'
# DIRECTORY_SCOPES='directory:read'
# OPENCLARION_IAM_DIRECTORY_SCOPES='directory:read'
# Optional server-owned periodic full sync. Leave unset for manual sync only.
# Use 3600 or higher in production unless IAM explicitly supports a lower
# polling interval.
# OPENCLARION_IAM_DIRECTORY_SYNC_INTERVAL_SECONDS='3600'
# Directory sync requests disabled accounts from IAM so local RBAC can converge
# deprovisioned users to inactive instead of retaining stale active subjects.
# Required for the first start against a fresh isolated local database; also
# available for emergency recovery. Subjects must still authenticate through
# IAM/diagnosis session; matched subjects are treated as global admins before
# persisted RBAC assignments exist. Remove this after creating at least one
# enabled global admin RBAC assignment in the active default workspace.
# Configured external databases are not inspected by the local launcher.
# OPENCLARION_RBAC_BOOTSTRAP_ADMIN_SUBJECTS='iam-subject-1,iam-subject-2'
# Optional Enterprise WeChat application message callback endpoint:
# /api/v1/diagnosis/wecom/app-callback. Use these only for the app "receive
# messages" callback; they are separate from OAuth browser login settings.
# OPENCLARION_WECOM_CALLBACK_TOKEN='replace-with-private-callback-token'
# OPENCLARION_WECOM_CALLBACK_ENCODING_AES_KEY='replace-with-43-char-callback-aes-key'
# OPENCLARION_WECOM_CALLBACK_RECEIVE_ID='ww-replace-with-corp-id'
OPENCLARION_DIAGNOSIS_ALLOWED_ORIGINS='http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:3000,http://localhost:3000'
# Optional externally reachable browser base URL used in operator notification
# links, for example "https://openclarion.example.test".
# OPENCLARION_PUBLIC_BASE_URL='http://127.0.0.1:3000'

# OpenAI-compatible report and diagnosis LLM runtime. The launcher derives the
# report variables from the diagnosis variables, or the reverse, when only one
# side is supplied.
OPENCLARION_DIAGNOSIS_LLM_BASE_URL='https://llm.example.test/v1'
OPENCLARION_DIAGNOSIS_LLM_API_KEY='replace-with-private-api-key'
OPENCLARION_DIAGNOSIS_LLM_MODEL='replace-with-model-name'

# Optional historical report retrieval. Setting the model enables automatic
# indexing and advisory context for newly generated reports. Base URL and API
# key fall back to the report LLM gateway when their dedicated values are unset.
# OPENCLARION_EMBEDDING_MODEL='replace-with-1536-dimension-embedding-model'
# OPENCLARION_EMBEDDING_BASE_URL='https://llm.example.test/v1'
# OPENCLARION_EMBEDDING_API_KEY='replace-with-private-api-key'
# OPENCLARION_EMBEDDING_HTTP_TIMEOUT_SECONDS='30'

# Digest-pinned diagnosis assistant sandbox runtime and read-only agent config.
# Build the bundled proxy with `make local-egress-proxy-build` before starting
# the `sandbox-egress` Compose profile. The proxy has no published host port.
OPENCLARION_SANDBOX_IMAGE_REF='registry.example.test/openclarion/diagnosis-assistant-runner@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa'
OPENCLARION_SANDBOX_AGENT_CONFIG_ROOT='config/agents'
OPENCLARION_SANDBOX_EGRESS_ALLOWED='llm.example.test:443,metrics.example.test:443'
OPENCLARION_SANDBOX_EGRESS_NETWORK='openclarion-sandbox-allowlist'
OPENCLARION_SANDBOX_EGRESS_PROXY_URL='http://openclarion-egress-proxy:18080'

# Optional M4 report-enhancement evaluation. Build the bundled candidate with
# `make report-enhancer-runner-build`, then use its emitted digest reference.
# The M4-prefixed LLM values are injected only for one container invocation;
# the LLM host and port must be present in the M4 egress allowlist.
# OPENCLARION_M4_SANDBOX_IMAGE_REF='registry.example.test/openclarion/report-enhancer-runner@sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb'
# OPENCLARION_M4_SANDBOX_AGENT_CONFIG_ROOT='config/agents'
# OPENCLARION_M4_SANDBOX_EGRESS_ALLOWED='llm.example.test:443'
# OPENCLARION_M4_SANDBOX_EGRESS_NETWORK='openclarion-sandbox-allowlist'
# OPENCLARION_M4_SANDBOX_EGRESS_PROXY_URL='http://openclarion-egress-proxy:18080'
# OPENCLARION_M4_REPORT_LLM_BASE_URL='https://llm.example.test/v1'
# OPENCLARION_M4_REPORT_LLM_API_KEY='replace-with-private-api-key'
# OPENCLARION_M4_REPORT_LLM_MODEL='replace-with-model-name'
# OPENCLARION_M4_REPORT_LLM_OUTPUT_MODE='json_schema'
# OPENCLARION_M4_REPORT_LLM_HTTP_TIMEOUT_SECONDS='90'

# Profile-backed notification delivery. Store real webhook endpoints only in
# this ignored env file, then use the left-side secret_ref key in the
# notification channel profile. Enterprise WeChat channels expect the mapped
# value to be the private group robot webhook URL.
OPENCLARION_NOTIFICATION_CHANNEL_SECRET_REFS_JSON='{"secret/openclarion/ops-wecom":"replace-with-private-enterprise-wechat-webhook-url"}'

# Optional legacy direct IM fallback for unbound report delivery and older
# smoke runs. Profile-bound report and diagnosis-room notifications should use
# OPENCLARION_NOTIFICATION_CHANNEL_SECRET_REFS_JSON instead.
# OPENCLARION_IM_WEBHOOK_URL='https://webhook.example.test/openclarion'
# OPENCLARION_IM_WEBHOOK_FORMAT='wecom'

# Optional CMDB evidence enrichment. Configure either the generic HTTP adapter
# or the direct NetBox adapter, never both. Leave every CMDB variable unset to
# preserve the historical snapshot payload and digest shape.
#
# The generic endpoint must implement OpenClarion's bounded JSON-over-HTTP
# lookup contract. Keep bearer values only in this ignored private env file.
# OPENCLARION_CMDB_HTTP_URL='https://cmdb-gateway.example.test/v1/lookup'
# OPENCLARION_CMDB_HTTP_BEARER_TOKEN='replace-with-private-cmdb-token'
# OPENCLARION_CMDB_HTTP_TIMEOUT_SECONDS='10'
#
# NetBox 4.5.2+ within the 4.x series accepts the deployment root or its /api
# root. The lookup label is required; the filter defaults to name; object type
# defaults to auto (device plus virtual_machine with cross-type ambiguity
# rejected).
# Token scheme defaults to auto: nbt_ tokens use Bearer, older tokens use Token.
# OPENCLARION_CMDB_NETBOX_URL='https://netbox.example.test'
# OPENCLARION_CMDB_NETBOX_API_TOKEN='replace-with-private-netbox-api-token'
# OPENCLARION_CMDB_NETBOX_TOKEN_SCHEME='auto'
# OPENCLARION_CMDB_NETBOX_LOOKUP_LABEL='instance'
# OPENCLARION_CMDB_NETBOX_LOOKUP_FILTER='name'
# OPENCLARION_CMDB_NETBOX_OBJECT_TYPE='auto'
# OPENCLARION_CMDB_NETBOX_ATTRIBUTE_CUSTOM_FIELDS='criticality,environment'
# OPENCLARION_CMDB_NETBOX_TIMEOUT_SECONDS='10'

# Automatic diagnosis safety valve. Each alert intake or report-policy replay
# starts at most this many diagnosis rooms immediately; additional evidence
# snapshots remain available for manual room creation or later replay.
OPENCLARION_AUTO_DIAGNOSIS_MAX_ROOMS_PER_TRIGGER='3'
