# Local environment
.env
.env.*
!.env.example
/.openclarion-private/

# Build outputs
bin/
dist/
coverage/
/openclarion

# Local retained evidence artifacts (manual smoke/proof outputs).
/artifacts/

# Atlas drift / smoke gate scratch directories (recreated per run; never
# committed). See Makefile (`atlas-drift`, `atlas-smoke`) and
# scripts/check_atlas_drift.sh / scripts/check_atlas_smoke.sh.
/.atlas-drift-tmp/
/.atlas-smoke-tmp/

# Go
*.test
*.out

# Node
node_modules/
.next/
*.tsbuildinfo
playwright-report/
playwright-report-live/
test-results/
test-results-live/

# IDE
.idea/
.vscode/
.qoder/

# OS
.DS_Store

# Private agent workspace (separate git repository, must never enter the
# main OpenClarion repository). The directory may exist physically inside
# the working tree but its contents (including any nested .git/) are
# managed independently.
ai-code/
