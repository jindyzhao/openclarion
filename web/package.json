{
  "name": "@openclarion/web",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "smoke": "npm run build && npm run smoke:built",
    "smoke:built": "playwright test",
    "smoke:live": "npm run build && npm run smoke:live:built",
    "smoke:live:built": "playwright test --config playwright.live.config.ts",
    "deadcode": "knip --config knip.json",
    "audit": "npm audit --audit-level=high",
    "markdownlint": "markdownlint-cli2 --config ../docs/design/ci/markdownlint/.markdownlint-cli2.jsonc",
    "api:generate": "openapi-typescript ../api/openapi.yaml -o src/lib/api/openapi.ts"
  },
  "dependencies": {
    "@ant-design/cssinjs": "1.24.0",
    "@ant-design/icons": "5.6.1",
    "@ant-design/v5-patch-for-react-19": "1.0.3",
    "@tanstack/react-query": "5.101.0",
    "antd": "5.29.3",
    "next": "16.2.7",
    "next-intl": "4.13.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "knip": "6.14.2",
    "markdownlint-cli2": "0.22.1",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15",
    "js-yaml": "4.2.0",
    "markdown-it": "14.2.0"
  }
}
